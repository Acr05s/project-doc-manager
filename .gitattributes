# Auto detect text files and perform LF normalization
* text=auto

# Force shell scripts to always use LF line endings
*.sh text eol=lf
*.bash text eol=lf

# Force batch files to always use CRLF line endings
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
