# 本地配置文件：合并时总是使用本地版本，不参与冲突
settings.json merge=ours
permissions.json merge=ours

# Python 缓存目录：不参与合并
__pycache__/ -merge=diff
*.pyc -merge=diff

# 临时文件：不参与合并
*.tmp merge=nothing
*.log merge=nothing
*.cache merge=nothing

# Python 字节码：不参与合并
*.pyc merge=nothing
*.pyo merge=nothing

# 备份目录：不参与合并
backup_*/ merge=nothing

# 数据目录：不参与合并
data/ merge=nothing
uploads/ merge=nothing
logs/ merge=nothing
projects/ merge=nothing
